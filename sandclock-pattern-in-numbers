//sand clock pattern type-1
#include<stdio.h>
int main(){
int num;
scanf("%d",&num);
for(int row=num;row>=2;row--){
    for(int spaces=row+1;spaces<=num;spaces++){
        printf(" "); 
    }
    for(int col=1;col<2*row;col++){
        printf("%d",row);
    }
    printf("\n");
 }
 for(int row=1;row<=num;row++){
     for(int spaces=row+1;spaces<=num;spaces++){
         printf(" ");
     }
     for(int col=1;col<2*row;col++){
         printf("%d",row);
     }
     printf("\n");
 }
}
//sand clock pattern type-2
#include<stdio.h>
int main()
{
    int n;
    scanf("%d",&n);
    int x=1;
    
    for(int i=1;i<=n;i++)
    {
        for(int j=1;j<=n; j++)
        {
            if(j >= x && j<= n - x + 1)
            {
                printf("*");
            }
            else
            {
                printf(" ");
            }
        }
       if(i<=n/2)
        x++;
       else
        x--;
       printf("\n");
    }
return 0;
}

#include <stdio.h>
#include <stdlib.h>
int main() 
{
    int a, b, c;
    printf("Enter the values of a,b and c: ");
    scanf("%d %d %d", &a, &b, &c);
    printf("Before swap, a = %d,b = %d,c= %d", a, b, c);
    a = a + b + c;
    b = a - (b + c);
    c = a - (b + c);
    a = a- (b + c);
    printf("After swap, a = %d,b = %d,c=%d", a, b, c);
    return 0;
}
